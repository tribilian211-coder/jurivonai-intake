# ─── Required for production (Vercel + Neon Postgres) ────────────────────────
# Get this URL from https://neon.tech (free, Google login, 30 seconds):
#   1. Sign up at neon.tech
#   2. Create a project (any name, e.g. "jurivonai")
#   3. Copy the "Connection string" — looks like:
#      postgresql://neondb:AbCdEf123456@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#   4. Paste it below as DATABASE_URL
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Admin dashboard password ────────────────────────────────────────────────
# Set this to a strong password. Used to access /#admin dashboard.
ADMIN_PASSWORD="change-this-to-a-strong-password"

# ─── For local SQLite dev only (ignore if using Postgres) ────────────────────
# If you want to run locally with SQLite instead of Postgres:
#   1. Replace prisma/schema.prisma with prisma/schema.sqlite.prisma
#   2. Uncomment the line below and comment out the Postgres DATABASE_URL above
# DATABASE_URL="file:./db/custom.db"
